{
    "name": "B站连播助手 (Bilibili Movie Control)",
    "description": "基于 SolidJS 开发的 Bilibili 视频跳转工具",
    "private": true,
    "version": "1.0.3",
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "dev:edge": "wxt -b edge",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare",
        "change": "bun changeset",
        "version": "bun changeset version",
        "status": "bun changeset status",
        "release": "bun run build:all && bun run zip:all && bun run submit:firefox && bun run submit:edge",
        "build:all": "wxt build -b firefox && wxt build -b edge",
        "zip:all": "wxt zip -b firefox && wxt zip -b edge",
        "submit:firefox": "wxt submit --firefox-zip .output/*firefox*.zip",
        "submit:edge": "wxt submit --edge-zip .output/*edge*.zip"
    },
    "dependencies": {
        "solid-js": "^1.9.11"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@wxt-dev/module-solid": "^1.1.4",
        "typescript": "^5.9.3",
        "wxt": "^0.20.20"
    }
}